# FASHN.ai API設定
FASHN_API_KEY=your_fashn_api_key_here

# 楽天ウェブサービス API設定
# RAKUTEN_APP_ID: 管理画面の「アプリID」(数字のID)
RAKUTEN_APP_ID=your_numeric_app_id_here
# RAKUTEN_ACCESS_KEY: 管理画面の「アクセスキー」(pk_から始まる文字列)
RAKUTEN_ACCESS_KEY=your_access_key_here
RAKUTEN_AFFILIATE_ID=your_rakuten_affiliate_id_here

# サーバー設定（必要に応じて変更）
HOST=0.0.0.0
PORT=8000
